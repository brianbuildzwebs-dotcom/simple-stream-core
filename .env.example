# Supabase — required for auth, chat, and admin features
# Create a project at https://supabase.com and copy these from Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google sign-in (Supabase Dashboard → Authentication → Providers → Google)
# 1. Enable Google provider and paste OAuth Client ID + Secret from Google Cloud Console
# 2. Google Cloud → Authorized redirect URI:
#    https://YOUR-PROJECT.supabase.co/auth/v1/callback
# 3. Supabase → Authentication → URL Configuration → Redirect URLs (add each origin):
#    http://localhost:5173/auth/callback
#    https://simple-stream-core.brianbuildzwebs.workers.dev/auth/callback

# RTMP / Cloudflare Stream (optional — for live streaming)
VITE_RTMP_SERVER_URL=rtmps://live.cloudflare.com:443/live/
VITE_RTMP_STREAM_KEY=your-cloudflare-stream-key
# HLS playback URL from Cloudflare Stream → Live Input → HLS Manifest URL
VITE_RTMP_HLS_URL=https://customer-xxxxxxxx.cloudflarestream.com/xxxxxxxxxxxxxxxx/manifest/video.m3u8
# Optional: customer code only (used to build HLS URL from stream key if HLS URL is empty)
VITE_RTMP_CUSTOMER_CODE=xxxxxxxx

# Optional: YouTube Data API key — improves LIVE badge detection for playlists
# https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3)
VITE_YOUTUBE_API_KEY=your-youtube-api-key

# Sentry — error monitoring (optional)
# Client DSN from Sentry → Settings → Projects → Client Keys
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Build-time only — upload source maps during CI/production builds
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=simple-stream-core

# Optional: YouTube Innertube key for /api/youtube-live LIVE badges.
# Usually not needed — the Worker fetches a public key from YouTube automatically.
# YOUTUBE_INNERTUBE_KEY=your-innertube-key

# Phase 1 — Simple Streamz seller platform (Worker secrets, not VITE_)
# Set on Cloudflare Worker via: wrangler secret put <NAME>
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# LEGAL_AUDIT_SALT=random-secret-for-hashing-legal-audit-records
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  (Stripe → Developers → Webhooks → signing secret)

# Cloudflare Access — admin route gate (Worker vars, optional until Access is enabled)
# CF_ACCESS_TEAM_DOMAIN=https://yourteam.cloudflareaccess.com
# CF_ACCESS_AUD=your-access-application-aud-tag
# Setup: powershell -ExecutionPolicy Bypass -File scripts/setup-cloudflare-access.ps1

# Phase 2 — Cloudflare Stream live inputs (Worker secrets)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token-with-stream-edit
# CLOUDFLARE_STREAM_CUSTOMER_CODE=xxxxxxxx