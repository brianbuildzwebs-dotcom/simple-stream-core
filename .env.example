# Supabase — required for auth, chat, and admin features
# Create a project at https://supabase.com and copy these from Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# RTMP / Cloudflare Stream (optional — for live streaming)
VITE_RTMP_SERVER_URL=rtmps://live.cloudflare.com:443/live/
VITE_RTMP_STREAM_KEY=your-cloudflare-stream-key
# HLS playback URL from Cloudflare Stream → Live Input → Playback
VITE_RTMP_HLS_URL=https://customer-xxxxxxxx.cloudflarestream.com/xxxxxxxxxxxxxxxx/manifest/video.m3u8