# Supabase — required for auth, chat, and admin features
# Create a project at https://supabase.com and copy these from Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# RTMP / Cloudflare Stream (optional — for live streaming)
VITE_RTMP_SERVER_URL=rtmps://live.cloudflare.com:443/live/
VITE_RTMP_STREAM_KEY=your-cloudflare-stream-key
# HLS playback URL from Cloudflare Stream → Live Input → HLS Manifest URL
VITE_RTMP_HLS_URL=https://customer-xxxxxxxx.cloudflarestream.com/xxxxxxxxxxxxxxxx/manifest/video.m3u8
# Optional: customer code only (used to build HLS URL from stream key if HLS URL is empty)
VITE_RTMP_CUSTOMER_CODE=xxxxxxxx

# Optional: YouTube Data API key — improves LIVE badge detection for playlists
# https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3)
VITE_YOUTUBE_API_KEY=your-youtube-api-key

# YouTube Innertube key — server-side only, used by /api/youtube-live for LIVE badges
# Find it: open youtube.com → DevTools → Network → filter "player" → copy the `key=` param
# from a youtubei/v1/player request. Do not commit the real value.
YOUTUBE_INNERTUBE_KEY=your-innertube-key

# Cloudflare Workers Builds:
#   Build variables: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, etc.
#   Runtime secret (Settings → Variables & Secrets): YOUTUBE_INNERTUBE_KEY