{
  "name": "simple-stream-core",
  "description": "Multi-source video streaming player with live chat (React + Vite + Supabase)",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.mjs",
    "postbuild": "node scripts/cf-deploy-if-ci.mjs",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy --old-asset-ttl 0",
    "deploy:ci": "node scripts/workers-ci-deploy.mjs",
    "pages:deploy": "npm run build && wrangler deploy --old-asset-ttl 0",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2024-09-23",
    "stripe:fix-key": "powershell -ExecutionPolicy Bypass -File scripts/fix-stripe-secret-key.ps1"
  },
  "dependencies": {
